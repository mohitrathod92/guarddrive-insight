generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Driver {
  id           String     @id @default(uuid())
  name         String
  route        String
  routeNum     Int
  status       String     @default("Safe")   // Safe | Warning | Critical
  lat          Float      @default(23.022)
  lng          Float      @default(72.571)
  speed        Float      @default(0)
  fatigueScore Int        @default(100)
  shift        String     @default("08:00-16:00")
  hoursOnDuty  Float      @default(0)
  vehicleNo    String     @default("")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  incidents    Incident[]
  speedLogs    SpeedLog[]
}

model Incident {
  id         String   @id @default(uuid())
  driverId   String
  driver     Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  type       String                            // Eye Closure | Drowsiness | Head Drooping | OverSpeeding | Harsh Brake | Sharp Turn
  severity   String                            // High | Medium | Low
  duration   Float    @default(0)              // seconds
  speed      Float    @default(0)
  zoneLimit  Float    @default(60)
  zone       String   @default("Highway")
  timestamp  DateTime @default(now())
}

model SpeedLog {
  id        String   @id @default(uuid())
  driverId  String
  driver    Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  speed     Float
  zone      String
  zoneLimit Float
  status    String                             // SAFE | WARNING | HIGH | CRITICAL
  timestamp DateTime @default(now())
}

model FleetVehicle {
  id         String   @id @default(uuid())
  vehicleNo  String   @unique
  routeName  String
  routeNum   Int
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
}
